<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Drone Project — Joyal Varghese</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Montserrat:wght@200;300;400;500;600&family=Courier+Prime:wght@400;700&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}

:root{
  --bg:#07090f;
  --surface:#0b0e18;
  --card:#0f1220;
  --border:#1e2235;
  --border-blue:#2a4a8a;
  --blue:#4a8fd4;
  --blue-bright:#6fb0f0;
  --blue-dim:#1a2d4a;
  --cream:#c0d0e8;
  --white:#e8f0f8;
  --muted:#3a4560;
  --text:#7a90b8;
  --text-light:#a0b8d8;
  --green:#007a4d;
  --red:#8a3030;
}

html{scroll-behavior:smooth}

body{
  background:var(--bg);
  color:var(--text);
  font-family:'Montserrat',sans-serif;
  font-weight:300;
  overflow-x:hidden;
  min-height:100vh;
}

/* GRAIN */
body::before{
  content:'';position:fixed;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  pointer-events:none;z-index:9999;opacity:0.6;
}

/* STAR FIELD */
body::after{
  content:'';position:fixed;inset:0;
  background-image:
    radial-gradient(1px 1px at 15% 20%, rgba(100,160,255,0.4) 0%, transparent 100%),
    radial-gradient(1px 1px at 72% 8%,  rgba(100,160,255,0.3) 0%, transparent 100%),
    radial-gradient(1px 1px at 40% 55%, rgba(100,160,255,0.2) 0%, transparent 100%),
    radial-gradient(1px 1px at 88% 35%, rgba(100,160,255,0.35) 0%, transparent 100%),
    radial-gradient(1px 1px at 5%  80%, rgba(100,160,255,0.25) 0%, transparent 100%),
    radial-gradient(1px 1px at 60% 90%, rgba(100,160,255,0.2) 0%, transparent 100%),
    radial-gradient(1px 1px at 30% 70%, rgba(100,160,255,0.3) 0%, transparent 100%),
    radial-gradient(2px 2px at 92% 65%, rgba(100,160,255,0.15) 0%, transparent 100%);
  pointer-events:none;z-index:0;
}

/* PAGE LOAD ANIMATION */
@keyframes fadeUp{
  from{opacity:0;transform:translateY(24px)}
  to{opacity:1;transform:translateY(0)}
}
@keyframes rotor{
  from{transform:rotate(0deg)}
  to{transform:rotate(360deg)}
}
@keyframes pulse{
  0%,100%{opacity:0.6}
  50%{opacity:1}
}
.fade-up{animation:fadeUp 0.8s ease forwards;opacity:0;}
.d1{animation-delay:0.1s}
.d2{animation-delay:0.25s}
.d3{animation-delay:0.4s}
.d4{animation-delay:0.55s}
.d5{animation-delay:0.7s}
.d6{animation-delay:0.85s}

/* ═══ TOP BAR ═══ */
.top-bar{
  background:linear-gradient(90deg,#050810,#0a1228,#050810);
  border-bottom:1px solid var(--border-blue);
  padding:10px 72px;
  display:flex;justify-content:space-between;align-items:center;
  position:relative;z-index:10;
}
.top-bar span{
  font-size:9px;letter-spacing:4px;text-transform:uppercase;
  color:rgba(100,160,255,0.55);font-weight:400;
}
.top-bar .status-dot{
  display:inline-block;width:6px;height:6px;border-radius:50%;
  background:var(--blue);margin-right:8px;
  animation:pulse 2s ease-in-out infinite;
}

/* ═══ HEADER ═══ */
header{
  padding:64px 72px 0;
  border-bottom:1px solid var(--border-blue);
  background:linear-gradient(160deg,#07090f 0%,#0d1225 60%,#07090f 100%);
  position:relative;overflow:hidden;z-index:1;
}

header::after{
  content:'';position:absolute;
  right:-80px;top:-80px;
  width:600px;height:600px;
  background:radial-gradient(circle,rgba(74,143,212,0.06) 0%,transparent 65%);
  pointer-events:none;
}

/* Animated drone SVG in header background */
.drone-bg{
  position:absolute;right:340px;top:40px;
  opacity:0.04;pointer-events:none;
}

.header-inner{
  display:grid;grid-template-columns:1fr 280px;gap:48px;align-items:start;
}

.crown-row{
  display:flex;align-items:center;gap:18px;margin-bottom:18px;
}
.crown-row .brand-tag{
  font-size:9px;letter-spacing:5px;text-transform:uppercase;
  color:var(--blue);font-weight:500;
}

h1{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:clamp(40px,6vw,72px);
  font-weight:300;color:var(--white);
  line-height:1.05;letter-spacing:-0.5px;
}
h1 em{font-style:italic;color:var(--blue-bright);}

.header-desc{
  font-size:12px;line-height:2;color:var(--text);
  margin-top:20px;max-width:560px;font-weight:300;
}

.btn-row{display:flex;gap:14px;margin-top:28px;flex-wrap:wrap;}

.github-link{
  display:inline-flex;align-items:center;gap:10px;
  border:1px solid var(--border-blue);
  padding:12px 24px;
  font-size:9px;letter-spacing:4px;text-transform:uppercase;
  color:var(--blue);font-weight:500;
  text-decoration:none;
  transition:background 0.3s,color 0.3s;
}
.github-link:hover{background:rgba(74,143,212,0.08);}
.github-link svg{width:14px;height:14px;fill:var(--blue);}

.wokwi-link{
  display:inline-flex;align-items:center;gap:10px;
  border:1px solid #2a6040;
  padding:12px 24px;
  font-size:9px;letter-spacing:4px;text-transform:uppercase;
  color:#4ac890;font-weight:500;
  text-decoration:none;
  transition:background 0.3s;
  background:rgba(0,180,100,0.04);
}
.wokwi-link:hover{background:rgba(74,200,144,0.1);}
.wokwi-link svg{width:14px;height:14px;}

/* RIGHT CARD */
.repo-card{
  background:linear-gradient(145deg,#0f1220,#090c17);
  border:1px solid var(--border-blue);
  padding:32px 28px;
  position:relative;
}
.repo-card::before{
  content:'';position:absolute;inset:4px;
  border:1px solid rgba(74,143,212,0.08);pointer-events:none;
}
.repo-card .rc-label{
  font-size:7px;letter-spacing:5px;text-transform:uppercase;
  color:var(--blue);font-weight:600;margin-bottom:16px;
}
.repo-card .rc-name{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:22px;color:var(--white);font-weight:400;
  line-height:1.2;
}
.repo-card .rc-divider{
  width:40px;height:1px;background:var(--border-blue);margin:16px 0;
}
.stat-row{display:flex;flex-direction:column;gap:10px;margin-top:4px;}
.stat-item{
  display:flex;justify-content:space-between;align-items:center;
  padding:8px 0;border-bottom:1px solid var(--border);
}
.stat-item:last-child{border-bottom:none;}
.stat-key{font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);font-weight:500;}
.stat-val{font-size:11px;color:var(--text-light);font-family:'Courier Prime',monospace;}
.stat-val.blue{color:var(--blue);}
.stat-val.fail{color:#c87878;}
.stat-val.ok{color:#78c878;}
.stat-val.live{color:#4ac890;}

/* DRONE ICON */
.drone-icon-wrap{
  display:flex;justify-content:center;margin:16px 0 8px;
}
.drone-icon-wrap svg{
  width:64px;height:64px;
}
.rotor-group{transform-origin:center;animation:rotor 0.4s linear infinite;}

/* BOTTOM SPEC BAR */
.spec-bar{
  display:grid;grid-template-columns:repeat(4,1fr);
  border-top:1px solid var(--border);
  margin-top:48px;
}
.spec-item{
  padding:24px 0;text-align:center;
  border-right:1px solid var(--border);
}
.spec-item:last-child{border-right:none;}
.spec-num{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:32px;font-weight:300;color:var(--blue-bright);
}
.spec-label{
  font-size:7px;letter-spacing:4px;text-transform:uppercase;
  color:var(--muted);margin-top:6px;font-weight:500;
}

/* ═══ ORNAMENT ═══ */
.ornament{
  display:flex;align-items:center;gap:14px;
  padding:18px 72px;position:relative;z-index:1;
}
.orn-line{flex:1;height:1px;background:linear-gradient(90deg,transparent,var(--border-blue),transparent);}
.orn-diamond{width:5px;height:5px;background:var(--blue-dim);transform:rotate(45deg);border:1px solid var(--border-blue);}
.orn-text{font-size:8px;letter-spacing:5px;text-transform:uppercase;color:var(--blue);font-weight:500;}

/* ═══ MAIN ═══ */
main{padding:0 72px 72px;position:relative;z-index:1;}

/* ═══ SECTION TITLE ═══ */
.section-head{
  display:flex;align-items:baseline;gap:20px;
  margin-bottom:32px;margin-top:56px;
}
.section-head h2{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:28px;font-weight:400;color:var(--white);
  font-style:italic;
}
.section-head .sh-line{
  flex:1;height:1px;
  background:linear-gradient(90deg,var(--border-blue),transparent);
}

/* ═══ WOKWI HERO CARD ═══ */
.wokwi-hero{
  background:linear-gradient(135deg,#0a1225,#071020);
  border:1px solid var(--border-blue);
  padding:40px 48px;
  position:relative;overflow:hidden;
  display:grid;grid-template-columns:1fr auto;gap:40px;align-items:center;
}
.wokwi-hero::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--blue),#4ac890,transparent);
}
.wokwi-hero::after{
  content:'';position:absolute;
  right:-60px;bottom:-60px;
  width:300px;height:300px;
  background:radial-gradient(circle,rgba(74,200,144,0.05) 0%,transparent 65%);
  pointer-events:none;
}
.wokwi-hero-label{
  font-size:8px;letter-spacing:5px;text-transform:uppercase;
  color:#4ac890;font-weight:600;margin-bottom:14px;
}
.wokwi-hero-title{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:32px;color:var(--white);font-weight:300;
  line-height:1.2;margin-bottom:14px;
}
.wokwi-hero-title em{font-style:italic;color:#4ac890;}
.wokwi-hero-desc{
  font-size:12px;line-height:2;color:var(--text);font-weight:300;
  max-width:520px;margin-bottom:24px;
}
.wokwi-features{
  display:flex;gap:24px;flex-wrap:wrap;margin-bottom:28px;
}
.wf-tag{
  font-size:8px;letter-spacing:3px;text-transform:uppercase;
  border:1px solid var(--border-blue);
  padding:6px 14px;color:var(--text-light);font-weight:500;
}
.wokwi-cta{
  display:inline-flex;align-items:center;gap:12px;
  background:rgba(74,200,144,0.08);
  border:1px solid #2a6040;
  padding:14px 28px;
  font-size:9px;letter-spacing:4px;text-transform:uppercase;
  color:#4ac890;font-weight:600;
  text-decoration:none;
  transition:background 0.3s;
}
.wokwi-cta:hover{background:rgba(74,200,144,0.15);}
.wokwi-cta svg{width:16px;height:16px;}

.wokwi-preview{
  width:200px;flex-shrink:0;
  display:flex;flex-direction:column;align-items:center;gap:8px;
}
.wokwi-preview-screen{
  width:180px;height:130px;
  background:#020408;
  border:1px solid var(--border-blue);
  position:relative;overflow:hidden;
  display:flex;align-items:center;justify-content:center;
}
.wokwi-preview-screen::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(180deg,rgba(74,143,212,0.05),transparent);
}
.terminal-text{
  font-family:'Courier Prime',monospace;
  font-size:9px;line-height:1.8;color:#4ac890;
  padding:12px;width:100%;
}
.t-dim{color:var(--muted);}
.wokwi-preview-label{
  font-size:8px;letter-spacing:3px;text-transform:uppercase;
  color:var(--muted);font-weight:500;
}

/* ═══ WORKFLOW SECTION ═══ */
.workflow-grid{
  display:grid;grid-template-columns:repeat(2,1fr);gap:2px;
}
.wf-card{
  background:var(--card);
  border:1px solid var(--border);
  padding:28px 32px;
  position:relative;
  transition:border-color 0.3s;
}
.wf-card:hover{border-color:var(--border-blue);}
.wf-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--wf-color,var(--blue)),transparent 70%);
}
.wf-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;}
.wf-num{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:48px;font-weight:300;color:var(--blue);opacity:0.12;line-height:1;
}
.wf-badge{
  border:1px solid var(--wf-color,var(--blue));
  padding:5px 14px;
  font-size:8px;letter-spacing:3px;text-transform:uppercase;
  color:var(--wf-color,var(--blue));font-weight:500;
}
.wf-title{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:20px;color:var(--white);font-weight:400;margin-bottom:8px;
}
.wf-file{font-family:'Courier Prime',monospace;font-size:11px;color:var(--muted);margin-bottom:14px;}
.wf-desc{font-size:12px;line-height:1.9;color:var(--text);font-weight:300;}
.wf-status{
  display:flex;align-items:center;gap:8px;
  margin-top:18px;padding-top:14px;
  border-top:1px solid var(--border);
}
.wf-dot{width:7px;height:7px;border-radius:50%;}
.wf-dot.fail{background:#c87878;box-shadow:0 0 6px rgba(200,120,120,0.5);}
.wf-dot.ok{background:#78c878;box-shadow:0 0 6px rgba(120,200,120,0.5);}
.wf-status-text{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);font-weight:500;}

/* ═══ WORKFLOW FILE BLOCK ═══ */
.file-block{
  background:linear-gradient(135deg,#050709,#080c15);
  border:1px solid var(--border);overflow:hidden;
}
.file-block-header{
  background:rgba(74,143,212,0.05);
  border-bottom:1px solid var(--border);
  padding:14px 24px;
  display:flex;align-items:center;justify-content:space-between;
}
.file-block-title{font-family:'Courier Prime',monospace;font-size:11px;color:var(--blue);}
.file-block-badge{font-size:7px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);font-weight:500;}
.code-body{
  padding:24px 28px;
  font-family:'Courier Prime',monospace;
  font-size:12px;line-height:2;color:#5a7a58;overflow-x:auto;
}
.cy{color:var(--blue);}
.cg{color:#6a9a60;}
.cm{color:#2a3a2a;}
.cv{color:#8070a0;}
.cs{color:#7a6850;}
.cw{color:var(--white);opacity:0.8;}

/* ═══ FEATURES GRID ═══ */
.features-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:2px;
}
.feat-card{
  background:var(--card);
  border:1px solid var(--border);
  padding:32px 28px;
  transition:border-color 0.3s;
  position:relative;overflow:hidden;
}
.feat-card:hover{border-color:var(--border-blue);}
.feat-card::after{
  content:'';position:absolute;bottom:0;right:0;width:80px;height:80px;
  background:radial-gradient(circle at bottom right,rgba(74,143,212,0.04),transparent 70%);
}
.feat-icon{
  width:44px;height:44px;
  border:1px solid var(--border-blue);
  display:flex;align-items:center;justify-content:center;margin-bottom:20px;
}
.feat-icon svg{width:20px;height:20px;fill:none;stroke:var(--blue);stroke-width:1.5;}
.feat-title{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:18px;color:var(--white);font-weight:400;margin-bottom:10px;
}
.feat-desc{font-size:12px;line-height:1.9;color:var(--text);font-weight:300;}

/* ═══ FIX GUIDE ═══ */
.fix-guide{background:var(--card);border:1px solid var(--border-blue);position:relative;overflow:hidden;}
.fix-guide::before{
  content:'';position:absolute;top:0;left:0;bottom:0;width:3px;
  background:linear-gradient(180deg,var(--blue),transparent);
}
.fix-guide-header{
  padding:28px 40px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:20px;
  background:rgba(74,143,212,0.03);
}
.fix-guide-header svg{width:20px;height:20px;fill:none;stroke:var(--blue);stroke-width:1.5;}
.fix-guide-title{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:22px;color:var(--white);font-weight:400;font-style:italic;
}
.fix-steps{display:grid;grid-template-columns:repeat(3,1fr);}
.fix-step{padding:28px 32px;border-right:1px solid var(--border);}
.fix-step:last-child{border-right:none;}
.fix-step-num{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:40px;color:var(--blue);opacity:0.2;font-weight:300;
  line-height:1;margin-bottom:10px;
}
.fix-step-title{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--blue);font-weight:600;margin-bottom:10px;}
.fix-step-desc{font-size:12px;line-height:1.9;color:var(--text);font-weight:300;}
.code-inline{
  display:inline-block;background:#050709;border:1px solid var(--border);
  padding:10px 16px;font-family:'Courier Prime',monospace;
  font-size:11px;color:var(--blue);margin-top:10px;width:100%;line-height:1.8;
}

/* ═══ FOOTER ═══ */
footer{
  border-top:1px solid var(--border-blue);
  padding:44px 72px;
  display:flex;justify-content:space-between;align-items:center;
  background:linear-gradient(90deg,var(--surface),var(--bg));
  position:relative;z-index:1;
}
.footer-left{display:flex;align-items:center;gap:18px;}
.footer-name{font-family:'Cormorant Garamond',Georgia,serif;font-size:20px;color:var(--blue);font-weight:400;}
.footer-sub{font-size:8px;letter-spacing:4px;text-transform:uppercase;color:var(--muted);margin-top:5px;}
.footer-right p{font-size:8px;color:var(--muted);letter-spacing:3px;text-transform:uppercase;text-align:right;margin-top:4px;}

@media(max-width:900px){
  .top-bar,.ornament{padding:10px 24px;}
  header{padding:40px 24px 0;}
  .header-inner{grid-template-columns:1fr;}
  main{padding:0 24px 48px;}
  .spec-bar{grid-template-columns:repeat(2,1fr);}
  .workflow-grid,.features-grid,.fix-steps{grid-template-columns:1fr;}
  .wokwi-hero{grid-template-columns:1fr;}
  .wokwi-preview{width:100%;flex-direction:row;justify-content:center;}
  footer{flex-direction:column;gap:20px;padding:32px 24px;text-align:center;}
  .footer-right p{text-align:center;}
}
</style>
</head>
<body>

<!-- TOP BAR -->
<div class="top-bar">
  <span><span class="status-dot"></span>JOYALVARGHESE07 / Drone-Sim</span>
  <span>Wokwi Simulation · Arduino Uno · Active</span>
</div>

<!-- HEADER -->
<header>
  <!-- Background drone silhouette -->
  <svg class="drone-bg" width="420" height="420" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
    <circle cx="100" cy="100" r="18" fill="none" stroke="#4a8fd4" stroke-width="2"/>
    <line x1="100" y1="82" x2="100" y2="40" stroke="#4a8fd4" stroke-width="1.5"/>
    <line x1="100" y1="118" x2="100" y2="160" stroke="#4a8fd4" stroke-width="1.5"/>
    <line x1="82" y1="100" x2="40" y2="100" stroke="#4a8fd4" stroke-width="1.5"/>
    <line x1="118" y1="100" x2="160" y2="100" stroke="#4a8fd4" stroke-width="1.5"/>
    <circle cx="100" cy="36" r="14" fill="none" stroke="#4a8fd4" stroke-width="1.5"/>
    <circle cx="100" cy="164" r="14" fill="none" stroke="#4a8fd4" stroke-width="1.5"/>
    <circle cx="36" cy="100" r="14" fill="none" stroke="#4a8fd4" stroke-width="1.5"/>
    <circle cx="164" cy="100" r="14" fill="none" stroke="#4a8fd4" stroke-width="1.5"/>
  </svg>

  <div class="header-inner">
    <div class="fade-up d1">
      <div class="crown-row">
        <!-- Drone propeller icon -->
        <svg viewBox="0 0 48 48" width="40" height="40" xmlns="http://www.w3.org/2000/svg">
          <circle cx="24" cy="24" r="5" fill="none" stroke="#4a8fd4" stroke-width="1.5"/>
          <line x1="24" y1="19" x2="24" y2="6" stroke="#4a8fd4" stroke-width="1.5"/>
          <line x1="24" y1="29" x2="24" y2="42" stroke="#4a8fd4" stroke-width="1.5"/>
          <line x1="19" y1="24" x2="6" y2="24" stroke="#4a8fd4" stroke-width="1.5"/>
