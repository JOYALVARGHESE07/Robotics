<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Robotics Project — Joyal Varghese</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Montserrat:wght@200;300;400;500;600&family=Courier+Prime:wght@400;700&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}

:root{
  --black:#09090700;
  --bg:#0a0a08;
  --surface:#111110;
  --card:#161612;
  --border:#252520;
  --border-gold:#7a6535;
  --gold:#c9a84c;
  --gold-bright:#e8c96d;
  --gold-dim:#4a3d20;
  --cream:#d4c9a0;
  --white:#f0ebe0;
  --muted:#5a5545;
  --text:#9a9070;
  --text-light:#c0b490;
  --green:#007a4d;
  --green-light:#00a366;
  --red:#8a3030;
}

html{scroll-behavior:smooth}

body{
  background:var(--bg);
  color:var(--text);
  font-family:'Montserrat',sans-serif;
  font-weight:300;
  overflow-x:hidden;
  min-height:100vh;
}

/* GRAIN */
body::before{
  content:'';position:fixed;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  pointer-events:none;z-index:9999;opacity:0.7;
}

/* PAGE LOAD ANIMATION */
@keyframes fadeUp{
  from{opacity:0;transform:translateY(24px)}
  to{opacity:1;transform:translateY(0)}
}
.fade-up{animation:fadeUp 0.8s ease forwards;opacity:0;}
.d1{animation-delay:0.1s}
.d2{animation-delay:0.25s}
.d3{animation-delay:0.4s}
.d4{animation-delay:0.55s}
.d5{animation-delay:0.7s}
.d6{animation-delay:0.85s}

/* ═══ TOP BAR ═══ */
.top-bar{
  background:var(--green);
  padding:10px 72px;
  display:flex;justify-content:space-between;align-items:center;
}
.top-bar span{
  font-size:9px;letter-spacing:4px;text-transform:uppercase;
  color:rgba(255,255,255,0.65);font-weight:400;
}

/* ═══ HEADER ═══ */
header{
  padding:64px 72px 0;
  border-bottom:1px solid var(--border-gold);
  background:linear-gradient(160deg,#0a0a08 0%,#141410 60%,#0a0a08 100%);
  position:relative;overflow:hidden;
}

header::after{
  content:'';position:absolute;
  right:-80px;top:-80px;
  width:500px;height:500px;
  background:radial-gradient(circle,rgba(201,168,76,0.04) 0%,transparent 65%);
  pointer-events:none;
}

.header-inner{
  display:grid;grid-template-columns:1fr 260px;gap:48px;align-items:start;
}

.crown-row{
  display:flex;align-items:center;gap:18px;margin-bottom:18px;
}
.crown-row .brand-tag{
  font-size:9px;letter-spacing:5px;text-transform:uppercase;
  color:var(--gold);font-weight:500;
}

h1{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:clamp(40px,6vw,72px);
  font-weight:300;color:var(--white);
  line-height:1.05;letter-spacing:-0.5px;
}
h1 em{font-style:italic;color:var(--gold);}

.header-desc{
  font-size:12px;line-height:2;color:var(--text);
  margin-top:20px;max-width:560px;font-weight:300;
}

.github-link{
  display:inline-flex;align-items:center;gap:10px;
  margin-top:28px;
  border:1px solid var(--border-gold);
  padding:12px 24px;
  font-size:9px;letter-spacing:4px;text-transform:uppercase;
  color:var(--gold);font-weight:500;
  text-decoration:none;
  transition:background 0.3s,color 0.3s;
}
.github-link:hover{background:rgba(201,168,76,0.08);}
.github-link svg{width:14px;height:14px;fill:var(--gold);}

/* RIGHT CARD */
.repo-card{
  background:linear-gradient(145deg,#161612,#0f0f0d);
  border:1px solid var(--border-gold);
  padding:32px 28px;
  position:relative;
}
.repo-card::before{
  content:'';position:absolute;inset:4px;
  border:1px solid rgba(201,168,76,0.1);pointer-events:none;
}
.repo-card .rc-label{
  font-size:7px;letter-spacing:5px;text-transform:uppercase;
  color:var(--gold);font-weight:600;margin-bottom:16px;
}
.repo-card .rc-name{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:22px;color:var(--white);font-weight:400;
  line-height:1.2;
}
.repo-card .rc-divider{
  width:40px;height:1px;background:var(--border-gold);margin:16px 0;
}
.stat-row{display:flex;flex-direction:column;gap:10px;margin-top:4px;}
.stat-item{
  display:flex;justify-content:space-between;align-items:center;
  padding:8px 0;border-bottom:1px solid var(--border);
}
.stat-item:last-child{border-bottom:none;}
.stat-key{font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);font-weight:500;}
.stat-val{font-size:11px;color:var(--text-light);font-family:'Courier Prime',monospace;}
.stat-val.gold{color:var(--gold);}
.stat-val.fail{color:#c87878;}
.stat-val.ok{color:#78c878;}

/* BOTTOM SPEC BAR */
.spec-bar{
  display:grid;grid-template-columns:repeat(4,1fr);
  border-top:1px solid var(--border);
  margin-top:48px;
}
.spec-item{
  padding:24px 0;text-align:center;
  border-right:1px solid var(--border);
}
.spec-item:last-child{border-right:none;}
.spec-num{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:32px;font-weight:300;color:var(--gold);
}
.spec-label{
  font-size:7px;letter-spacing:4px;text-transform:uppercase;
  color:var(--muted);margin-top:6px;font-weight:500;
}

/* ═══ ORNAMENT ═══ */
.ornament{
  display:flex;align-items:center;gap:14px;
  padding:18px 72px;
}
.orn-line{flex:1;height:1px;background:linear-gradient(90deg,transparent,var(--border-gold),transparent);}
.orn-diamond{width:5px;height:5px;background:var(--gold-dim);transform:rotate(45deg);border:1px solid var(--border-gold);}
.orn-text{font-size:8px;letter-spacing:5px;text-transform:uppercase;color:var(--gold);font-weight:500;}

/* ═══ MAIN ═══ */
main{padding:0 72px 72px;}

/* ═══ SECTION TITLE ═══ */
.section-head{
  display:flex;align-items:baseline;gap:20px;
  margin-bottom:32px;margin-top:56px;
}
.section-head h2{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:28px;font-weight:400;color:var(--white);
  font-style:italic;
}
.section-head .sh-line{
  flex:1;height:1px;
  background:linear-gradient(90deg,var(--border-gold),transparent);
}

/* ═══ WORKFLOW SECTION ═══ */
.workflow-grid{
  display:grid;grid-template-columns:repeat(2,1fr);gap:2px;
}

.wf-card{
  background:var(--card);
  border:1px solid var(--border);
  padding:28px 32px;
  position:relative;
  transition:border-color 0.3s;
}
.wf-card:hover{border-color:var(--border-gold);}
.wf-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--wf-color,var(--gold)),transparent 70%);
}

.wf-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;}
.wf-num{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:48px;font-weight:300;color:var(--gold);opacity:0.12;line-height:1;
}
.wf-badge{
  border:1px solid var(--wf-color,var(--gold));
  padding:5px 14px;
  font-size:8px;letter-spacing:3px;text-transform:uppercase;
  color:var(--wf-color,var(--gold));font-weight:500;
}

.wf-title{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:20px;color:var(--white);font-weight:400;
  margin-bottom:8px;
}
.wf-file{
  font-family:'Courier Prime',monospace;
  font-size:11px;color:var(--muted);margin-bottom:14px;
}
.wf-desc{font-size:12px;line-height:1.9;color:var(--text);font-weight:300;}

.wf-status{
  display:flex;align-items:center;gap:8px;
  margin-top:18px;padding-top:14px;
  border-top:1px solid var(--border);
}
.wf-dot{width:7px;height:7px;border-radius:50%;}
.wf-dot.fail{background:#c87878;box-shadow:0 0 6px rgba(200,120,120,0.5);}
.wf-dot.ok{background:#78c878;box-shadow:0 0 6px rgba(120,200,120,0.5);}
.wf-dot.pending{background:var(--gold);box-shadow:0 0 6px rgba(201,168,76,0.5);}
.wf-status-text{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);font-weight:500;}

/* ═══ WORKFLOW FILE BLOCK ═══ */
.file-block{
  background:#07070500;
  background:linear-gradient(135deg,#070705,#0d0d0a);
  border:1px solid var(--border);
  padding:0;overflow:hidden;
}
.file-block-header{
  background:rgba(201,168,76,0.05);
  border-bottom:1px solid var(--border);
  padding:14px 24px;
  display:flex;align-items:center;justify-content:space-between;
}
.file-block-title{
  font-family:'Courier Prime',monospace;
  font-size:11px;color:var(--gold);
}
.file-block-badge{
  font-size:7px;letter-spacing:3px;text-transform:uppercase;
  color:var(--muted);font-weight:500;
}
.code-body{
  padding:24px 28px;
  font-family:'Courier Prime',monospace;
  font-size:12px;line-height:2;
  color:#7a8a68;
  overflow-x:auto;
}
.cy{color:var(--gold);}
.cg{color:#8aaa70;}
.cm{color:#3a3a2a;}
.cv{color:#a89060;}
.cs{color:#907860;}
.cw{color:var(--white);opacity:0.8;}

/* ═══ FEATURES GRID ═══ */
.features-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:2px;
}
.feat-card{
  background:var(--card);
  border:1px solid var(--border);
  padding:32px 28px;
  transition:border-color 0.3s,transform 0.3s;
  position:relative;overflow:hidden;
}
.feat-card:hover{border-color:var(--border-gold);}
.feat-card::after{
  content:'';position:absolute;
  bottom:0;right:0;
  width:80px;height:80px;
  background:radial-gradient(circle at bottom right,rgba(201,168,76,0.04),transparent 70%);
}
.feat-icon{
  width:44px;height:44px;
  border:1px solid var(--border-gold);
  display:flex;align-items:center;justify-content:center;
  margin-bottom:20px;
}
.feat-icon svg{width:20px;height:20px;fill:none;stroke:var(--gold);stroke-width:1.5;}
.feat-title{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:18px;color:var(--white);font-weight:400;
  margin-bottom:10px;
}
.feat-desc{font-size:12px;line-height:1.9;color:var(--text);font-weight:300;}

/* ═══ FIX GUIDE ═══ */
.fix-guide{
  background:var(--card);
  border:1px solid var(--border-gold);
  position:relative;overflow:hidden;
}
.fix-guide::before{
  content:'';position:absolute;top:0;left:0;bottom:0;width:3px;
  background:linear-gradient(180deg,var(--gold),transparent);
}
.fix-guide-header{
  padding:28px 40px;
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:20px;
  background:rgba(201,168,76,0.03);
}
.fix-guide-header svg{width:20px;height:20px;fill:none;stroke:var(--gold);stroke-width:1.5;}
.fix-guide-title{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:22px;color:var(--white);font-weight:400;font-style:italic;
}
.fix-steps{
  display:grid;grid-template-columns:repeat(3,1fr);
}
.fix-step{
  padding:28px 32px;
  border-right:1px solid var(--border);
}
.fix-step:last-child{border-right:none;}
.fix-step-num{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:40px;color:var(--gold);opacity:0.2;font-weight:300;
  line-height:1;margin-bottom:10px;
}
.fix-step-title{
  font-size:11px;letter-spacing:2px;text-transform:uppercase;
  color:var(--gold);font-weight:600;margin-bottom:10px;
}
.fix-step-desc{font-size:12px;line-height:1.9;color:var(--text);font-weight:300;}

.code-inline{
  display:inline-block;
  background:#070705;
  border:1px solid var(--border);
  padding:10px 16px;
  font-family:'Courier Prime',monospace;
  font-size:11px;color:var(--gold);
  margin-top:10px;width:100%;line-height:1.8;
}

/* ═══ FOOTER ═══ */
footer{
  border-top:1px solid var(--border-gold);
  padding:44px 72px;
  display:flex;justify-content:space-between;align-items:center;
  background:linear-gradient(90deg,var(--surface),var(--bg));
}
.footer-left{display:flex;align-items:center;gap:18px;}
.footer-name{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:20px;color:var(--gold);font-weight:400;
}
.footer-sub{font-size:8px;letter-spacing:4px;text-transform:uppercase;color:var(--muted);margin-top:5px;}
.footer-right p{
  font-size:8px;color:var(--muted);letter-spacing:3px;
  text-transform:uppercase;text-align:right;margin-top:4px;
}

@media(max-width:900px){
  .top-bar,.ornament{padding:10px 24px;}
  header{padding:40px 24px 0;}
  .header-inner{grid-template-columns:1fr;}
  main{padding:0 24px 48px;}
  .spec-bar{grid-template-columns:repeat(2,1fr);}
  .workflow-grid,.features-grid,.fix-steps{grid-template-columns:1fr;}
  footer{flex-direction:column;gap:20px;padding:32px 24px;text-align:center;}
  .footer-right p{text-align:center;}
}
</style>
</head>
